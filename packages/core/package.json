{
  "name": "@chordlens/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ChordLens のプラットフォーム非依存コアロジック（音声解析・プリセット・ログ CSV）。Web / モバイルの両方から利用する。",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.dev.json --noEmit",
    "analyze:file": "tsx scripts/analyze-audio-file.ts"
  },
  "dependencies": {
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^20",
    "ffmpeg-static": "^5.3.0",
    "fft.js": "^4.0.4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
