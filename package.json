{
  "name": "chordlens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "pnpm --filter @chordlens/web dev",
    "build": "pnpm --filter @chordlens/web build",
    "preview": "pnpm --filter @chordlens/web preview",
    "test": "pnpm -r test",
    "test:watch": "pnpm --filter @chordlens/web test:watch",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "analyze:file": "pnpm --filter @chordlens/core analyze:file",
    "pages:dev": "pnpm --filter @chordlens/web pages:dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript": "^5",
    "typescript-eslint": "^8.20.0"
  }
}
