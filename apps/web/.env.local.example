# Firebase configuration for /experiments participant flow.
# Copy to `.env.local` and fill in values from Firebase console
# (Project settings -> General -> Your apps -> Web app).
#
# Vite inlines these at build time via the VITE_ prefix.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=

# Optional: client-side log forwarding
VITE_CLIENT_LOG=
VITE_CLIENT_LOG_FPS=
